{% comment %}
  Renders prepaid conversion nudge for cart/drawer contexts.
  Variables:
    prepaid_savings — string like "₹50" (default "₹50")
    compact — boolean, renders a slimmer version for drawer (default false)
{% endcomment %}

{%- assign prepaid_savings = prepaid_savings | default: '₹50' -%}

{%- if compact -%}
  <div class="hpb hpb--compact">
    <span class="hpb__icon">💳</span>
    <span class="hpb__text">Pay online & save <strong>{{ prepaid_savings }}</strong> extra · UPI · Card · Net Banking</span>
  </div>
{%- else -%}
  <div class="hpb">
    <div class="hpb__left">
      <span class="hpb__icon">💳</span>
      <div>
        <div class="hpb__title">Pay Online · Save <span class="hpb__badge">{{ prepaid_savings }}</span></div>
        <div class="hpb__sub">Use UPI, Card, or Net Banking at checkout</div>
      </div>
    </div>
    <div class="hpb__cod">
      <span class="hpb__cod-icon">🏠</span>
      <span class="hpb__cod-text">COD also available</span>
    </div>
  </div>
{%- endif -%}

<style>
  .hpb {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: linear-gradient(135deg, #FFF8F0, #FFF3E6);
    border: 1.5px solid #F5A623;
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 12px;
  }
  .hpb--compact {
    padding: 9px 12px;
    gap: 8px;
    justify-content: flex-start;
  }
  .hpb__left { display: flex; align-items: center; gap: 10px; }
  .hpb__icon { font-size: 2rem; line-height: 1; flex-shrink: 0; }
  .hpb__title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #B25900;
    margin-bottom: 2px;
  }
  .hpb__sub { font-size: 1.15rem; color: #7A4500; }
  .hpb__badge {
    display: inline-block;
    background: #F5A623;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 20px;
    margin-left: 2px;
  }
  .hpb__cod {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
    border-left: 1px solid rgba(245,166,35,.4);
    padding-left: 12px;
  }
  .hpb__cod-icon { font-size: 1.6rem; }
  .hpb__cod-text { font-size: 1.1rem; color: #7A4500; font-weight: 600; text-align: center; }
  .hpb--compact .hpb__text { font-size: 1.25rem; color: #B25900; }
  .hpb--compact .hpb__text strong { color: #8B4000; }
</style>
