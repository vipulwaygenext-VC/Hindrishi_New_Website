      { "type": "review", "settings": { "rating": 5, "title": "My doctor suggested Ayurvedic and I chose Hindrishi", "review": "Instead of going for heavy medicines, I wanted something natural. This syrup has been amazing. No side effects, and I definitely feel the difference in my overall energy and appetite.", "author_name": "Priya Sharma", "author_location": "Mumbai", "product": "Liv-Revive Liver Syrup", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "title": "The self-care ritual I needed", "review": "Between work and family, I never took time for myself. This oil has changed that. My skin is softer but honestly, the mental wellness benefit is even better. Thank you Hindrishi.", "author_name": "Meera Nair", "author_location": "Chennai", "product": "Breast Care Oil", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "title": "Quality Ayurvedic care", "review": "Been using for 2 months consistently and my overall wellness has improved. No more that heavy, tired feeling. I appreciate that it's all natural herbs. Highly recommend.", "author_name": "Dr. Amit Verma", "author_location": "Bangalore", "product": "Kidney Wellness Support", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "title": "Ayurvedic solution that actually works", "review": "Mujhe chemical treatments se dar lagta tha. This natural formula gave me confidence to try. Application is very precise. Seeing visible difference in 4 weeks. Will definitely recommend.", "author_name": "Rahul Sharma", "author_location": "Delhi", "product": "Wart Remover", "verified": true } },
      { "type": "review", "settings": { "rating": 5, "title": "Oily khane ke baad ab woh bharipan nahi rehta", "review": "Mujhe toh lagta tha ki yeh permanent problem hai. But after using this for 2 months regularly, I can eat normal food without feeling that uncomfortable heaviness. Good product at good price.", "author_name": "Amit Verma", "author_location": "Bangalore", "product": "Liv-Revive Liver Syrup", "verified": true } }
    ]
  }]
}
{% endschema %}
