
{%- style -%}
  .hstory-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .hstory-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="hstory hstory-{{ section.id }}" style="background:{{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="hstory__layout {% if section.settings.image_position == 'right' %}hstory__layout--img-right{% endif %}">

      <div class="hstory__img-wrap {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 700
            | image_tag: loading: 'lazy', class: 'hstory__img', alt: section.settings.image.alt | escape
          }}
        {%- else -%}
          <span class="hstory__img-placeholder">🌿</span>
        {%- endif -%}
      </div>

      <div class="hstory__content {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
        <span class="hindrishi-section-tag hstory__tag">{{ section.settings.tag }}</span>
        <h2 class="hindrishi-section-heading hstory__heading">{{ section.settings.heading }}</h2>
        <div class="hindrishi-divider hindrishi-divider--left"></div>
        <p class="hstory__desc">{{ section.settings.description }}</p>

        <div class="hstory__stats">
          {%- if section.settings.stat1_number != blank -%}
            <div class="hstory__stat">
              <span class="hstory__stat-num">{{ section.settings.stat1_number }}</span>
              <span class="hstory__stat-label">{{ section.settings.stat1_label }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.stat2_number != blank -%}
            <div class="hstory__stat">
              <span class="hstory__stat-num">{{ section.settings.stat2_number }}</span>
              <span class="hstory__stat-label">{{ section.settings.stat2_label }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.stat3_number != blank -%}
            <div class="hstory__stat">
              <span class="hstory__stat-num">{{ section.settings.stat3_number }}</span>
              <span class="hstory__stat-label">{{ section.settings.stat3_label }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link }}" class="hindrishi-btn-primary">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<style>
  .hstory__layout--img-right { direction: rtl; }
  .hstory__layout--img-right > * { direction: ltr; }
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",         "id": "tag",             "label": "Section Tag",    "default": "Our Story" },
    { "type": "text",         "id": "heading",         "label": "Heading",        "default": "Rooted in Tradition, Crafted for Today" },
    { "type": "textarea",     "id": "description",     "label": "Description",    "default": "Hindrishi Ayurveda was born from a deep respect for India's 5,000-year healing tradition. We believe that nature has answers for every wellness challenge — when those answers are properly researched, tested, and formulated with care. Every product we create bridges the gap between ancient Ayurvedic wisdom and modern quality standards." },
    { "type": "image_picker", "id": "image",           "label": "Image" },
    { "type": "select",       "id": "image_position",  "label": "Image Position", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "text",         "id": "stat1_number",    "label": "Stat 1 Number",  "default": "40K+" },
    { "type": "text",         "id": "stat1_label",     "label": "Stat 1 Label",   "default": "Happy Families" },
    { "type": "text",         "id": "stat2_number",    "label": "Stat 2 Number",  "default": "5,000" },
    { "type": "text",         "id": "stat2_label",     "label": "Stat 2 Label",   "default": "Years of Wisdom" },
    { "type": "text",         "id": "stat3_number",    "label": "Stat 3 Number",  "default": "GMP" },
    { "type": "text",         "id": "stat3_label",     "label": "Stat 3 Label",   "default": "Certified Facilities" },
    { "type": "text",         "id": "cta_label",       "label": "CTA Label",      "default": "Learn More About Us" },
    { "type": "url",          "id": "cta_link",        "label": "CTA Link" },
    { "type": "color",        "id": "bg_color",        "label": "Background",     "default": "#F9F4EE" },
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
