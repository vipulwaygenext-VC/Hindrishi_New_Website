{{ 'hindrishi-brand.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .hfaq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .hfaq-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="hfaq hfaq-{{ section.id }}" style="background:{{ section.settings.bg_color }};">
  <div class="page-width">

    <div class="hfaq__header {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
      <span class="hindrishi-section-tag">{{ section.settings.tag }}</span>
      <h2 class="hindrishi-section-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="hindrishi-section-subheading" style="margin:0 auto;">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="hindrishi-divider"></div>
    </div>

    <div class="hfaq__wrap">
      {%- for block in section.blocks -%}
        <details class="hfaq__item {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
          <summary class="hfaq__q">
            <span>{{ block.settings.question }}</span>
            <span class="hfaq__icon" aria-hidden="true">
              <svg class="hfaq__icon--plus"  width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 4v10M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              <svg class="hfaq__icon--minus" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
          </summary>
          <div class="hfaq__a">
            <div class="hfaq__a-inner">{{ block.settings.answer }}</div>
          </div>
        </details>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="hfaq__cta {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--fade-in{% endif %}">
        {%- if section.settings.cta_text != blank -%}
          <p>{{ section.settings.cta_text }}</p>
        {%- endif -%}
        <a href="{{ section.settings.cta_link }}" class="hindrishi-btn-secondary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .hfaq__header { text-align: center; margin-bottom: 48px; }

  .hfaq__wrap {
    max-width: 800px;
    margin: 0 auto;
    border: 1px solid var(--hindrishi-border);
    border-radius: var(--hindrishi-radius-md);
    overflow: hidden;
  }

  .hfaq__item {
    border-bottom: 1px solid var(--hindrishi-border);
    background: #fff;
  }
  .hfaq__item:last-child { border-bottom: none; }

  .hfaq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    font-size: 1.55rem;
    font-weight: 600;
    color: var(--hindrishi-text-dark);
    transition: background .15s;
    user-select: none;
  }
  .hfaq__q:hover { background: var(--hindrishi-cream); }
  .hfaq__q::-webkit-details-marker { display: none; }

  .hfaq__icon {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--hindrishi-green-pale);
    color: var(--hindrishi-green);
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .hfaq__icon--minus { display: none; }

  .hfaq__item[open] .hfaq__icon { background: var(--hindrishi-green); color: #fff; }
  .hfaq__item[open] .hfaq__icon--plus  { display: none; }
  .hfaq__item[open] .hfaq__icon--minus { display: block; }
  .hfaq__item[open] .hfaq__q { background: var(--hindrishi-cream); color: var(--hindrishi-green); }

  .hfaq__a { padding: 0 24px 20px; background: var(--hindrishi-cream); }
  .hfaq__a-inner {
    font-size: 1.45rem;
    color: var(--hindrishi-text-medium);
    line-height: 1.7;
    border-top: 1px solid var(--hindrishi-border-light);
    padding-top: 16px;
  }

  .hfaq__cta {
    text-align: center;
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .hfaq__cta p { font-size: 1.6rem; color: var(--hindrishi-text-medium); margin: 0; }
</style>

{% schema %}
{
  "name": "FAQ Section",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",  "id": "tag",        "label": "Section Tag",  "default": "FAQ" },
    { "type": "text",  "id": "heading",    "label": "Heading",      "default": "Frequently Asked Questions" },
    { "type": "text",  "id": "subheading", "label": "Subheading",   "default": "Everything you need to know about Hindrishi products" },
    { "type": "color", "id": "bg_color",   "label": "Background",   "default": "#F9F4EE" },
    { "type": "text",  "id": "cta_text",   "label": "CTA Text",     "default": "Still have questions? We're here to help." },
    { "type": "text",  "id": "cta_label",  "label": "CTA Button",   "default": "Contact Us" },
    { "type": "url",   "id": "cta_link",   "label": "CTA Link" },
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [{
    "type": "faq", "name": "FAQ Item",
    "settings": [
      { "type": "text",     "id": "question", "label": "Question", "default": "Your question here?" },
      { "type": "richtext", "id": "answer",   "label": "Answer",   "default": "<p>Your answer here.</p>" }
    ]
  }],
  "presets": [{
    "name": "FAQ Section",
    "blocks": [
      { "type": "faq", "settings": { "question": "Are Hindrishi products safe for daily use?", "answer": "<p>Yes. All our products are 100% Ayurvedic formulations made with natural herbs and manufactured in GMP-certified facilities. They are designed for regular daily use. However, if you have existing medical conditions or are on medication, we recommend consulting your doctor before starting any new supplement.</p>" } },
      { "type": "faq", "settings": { "question": "How long does it take to see results?", "answer": "<p>Ayurvedic wellness works gradually and naturally. Most customers notice improvements within 3–4 weeks of consistent daily use. For comprehensive results, we recommend using our products for at least 8–12 weeks. Consistency and lifestyle support (diet, hydration, sleep) amplify results.</p>" } },
      { "type": "faq", "settings": { "question": "Do you offer Cash on Delivery (COD)?", "answer": "<p>Yes, we offer COD across India. Pay only when you receive the product at your doorstep. We also encourage prepaid orders (UPI/Card/Net Banking) — prepaid customers enjoy priority dispatch, faster delivery, and exclusive discounts of up to ₹70 off.</p>" } },
      { "type": "faq", "settings": { "question": "Are your products certified?", "answer": "<p>Absolutely. All Hindrishi products are FSSAI licensed, manufactured in GMP-certified facilities, AYUSH compliant, and undergo third-party lab testing for purity and safety. We maintain the highest quality standards at every step.</p>" } },
      { "type": "faq", "settings": { "question": "How fast is delivery?", "answer": "<p>We typically dispatch orders within 24–48 hours. Delivery takes 3–7 business days depending on your location. Metro cities receive faster delivery. Prepaid orders always get priority dispatch.</p>" } },
      { "type": "faq", "settings": { "question": "Are Hindrishi products 100% vegetarian?", "answer": "<p>Yes, all Hindrishi products are 100% vegetarian. All ingredients are plant-based. No animal-derived ingredients are used, and we are committed to cruelty-free practices — no animal testing whatsoever.</p>" } }
    ]
  }]
}
{% endschema %}
