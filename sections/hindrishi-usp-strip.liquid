{{ 'hindrishi-brand.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .husp-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .husp-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="husp husp-{{ section.id }}"
     style="background:{{ section.settings.bg_color }};border-top:1px solid var(--hindrishi-border);border-bottom:1px solid var(--hindrishi-border);">
  <div class="page-width">
    <ul class="husp__list" role="list">
      {%- for block in section.blocks -%}
        <li class="husp__item {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}>
          <div class="husp__icon-wrap" style="background:{{ block.settings.icon_bg }};">
            {%- if block.settings.icon_image != blank -%}
              {{
                block.settings.icon_image
                | image_url: width: 52
                | image_tag: loading: 'lazy', alt: block.settings.title, class: 'husp__icon-img'
              }}
            {%- else -%}
              <span class="husp__icon-emoji" aria-hidden="true">{{ block.settings.icon_emoji }}</span>
            {%- endif -%}
          </div>
          <div class="husp__text">
            <div class="husp__title">{{ block.settings.title }}</div>
            {%- if block.settings.subtitle != blank -%}
              <div class="husp__subtitle">{{ block.settings.subtitle }}</div>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

<style>
  .husp__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 16px;
    list-style: none;
    margin: 0; padding: 0;
  }
  @media screen and (min-width: 750px) {
    .husp__list { grid-template-columns: repeat(4, 1fr); gap: 32px; }
  }
  .husp__item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .husp__icon-wrap {
    width: 50px; height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .husp__icon-emoji { font-size: 2.2rem; line-height: 1; }
  .husp__icon-img   { width: 26px; height: 26px; object-fit: contain; }
  .husp__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--hindrishi-text-dark);
    line-height: 1.3;
    margin-bottom: 3px;
  }
  .husp__subtitle {
    font-size: 1.3rem;
    color: var(--hindrishi-text-light);
    line-height: 1.4;
  }
</style>

{% schema %}
{
  "name": "USP Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color",       "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 16, "max": 80, "step": 4, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 16, "max": 80, "step": 4, "default": 40 }
  ],
  "blocks": [{
    "type": "usp", "name": "USP Item",
    "settings": [
      { "type": "image_picker", "id": "icon_image",  "label": "Icon Image (optional)" },
      { "type": "text",         "id": "icon_emoji",  "label": "Icon Emoji (fallback)", "default": "🌿" },
      { "type": "color",        "id": "icon_bg",     "label": "Icon Background",       "default": "#DBE9E0" },
      { "type": "text",         "id": "title",       "label": "Title",                 "default": "100% Ayurvedic" },
      { "type": "text",         "id": "subtitle",    "label": "Subtitle",              "default": "Pure herbal formulations" }
    ]
  }],
  "presets": [{
    "name": "USP Strip",
    "blocks": [
      { "type": "usp", "settings": { "icon_emoji": "🌿", "title": "100% Ayurvedic", "subtitle": "Authentic herbal formulations", "icon_bg": "#DBE9E0" } },
      { "type": "usp", "settings": { "icon_emoji": "🏭", "title": "GMP Certified",  "subtitle": "Quality you can trust",         "icon_bg": "#FFDFB8" } },
      { "type": "usp", "settings": { "icon_emoji": "🧪", "title": "Lab Tested",     "subtitle": "Verified purity & safety",       "icon_bg": "#DBE9E0" } },
      { "type": "usp", "settings": { "icon_emoji": "👨‍👩‍👧","title": "40,000+ Families","subtitle": "Trusted across India",         "icon_bg": "#FFDFB8" } }
    ]
  }]
}
{% endschema %}
