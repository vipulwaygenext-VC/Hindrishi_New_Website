{{ 'hindrishi-brand.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .htimeline-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .htimeline-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="htimeline htimeline-{{ section.id }}" style="background:{{ section.settings.bg_color }};">
  <div class="page-width">

    <div class="htimeline__header {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
      <span class="hindrishi-section-tag">{{ section.settings.tag }}</span>
      <h2 class="hindrishi-section-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="hindrishi-section-subheading" style="margin:0 auto;">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="hindrishi-divider"></div>
    </div>

    <div class="htimeline__track">
      {%- for block in section.blocks -%}
        <div class="htimeline__item {% if forloop.index0 == 0 %}htimeline__item--first{% endif %} {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}"
             {{ block.shopify_attributes }}>

          <div class="htimeline__connector">
            <div class="htimeline__dot" style="background:{{ block.settings.dot_color }};"></div>
            {%- unless forloop.last -%}<div class="htimeline__line"></div>{%- endunless -%}
          </div>

          <div class="htimeline__card">
            <div class="htimeline__year" style="color:{{ block.settings.dot_color }};">{{ block.settings.year }}</div>
            <div class="htimeline__icon">{{ block.settings.icon }}</div>
            <h3 class="htimeline__title">{{ block.settings.title }}</h3>
            <p class="htimeline__desc">{{ block.settings.description }}</p>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .htimeline__header { text-align: center; margin-bottom: 56px; }

  .htimeline__track {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .htimeline__item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 0 24px;
    align-items: flex-start;
  }

  @media screen and (min-width: 750px) {
    .htimeline__item {
      grid-template-columns: 60px 1fr;
      gap: 0 32px;
    }
  }

  .htimeline__connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 20px;
  }
  .htimeline__dot {
    width: 18px; height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(45,90,39,.15);
    z-index: 1;
  }
  .htimeline__line {
    width: 2px;
    flex: 1;
    min-height: 32px;
    background: var(--hindrishi-border, #E8DDD0);
    margin-top: 6px;
  }

  .htimeline__card {
    background: #fff;
    border: 1px solid var(--hindrishi-border, #E8DDD0);
    border-radius: var(--hindrishi-radius-md, 12px);
    padding: 20px 22px;
    margin-bottom: 16px;
    box-shadow: var(--hindrishi-shadow-card);
  }
  .htimeline__year {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .htimeline__icon { font-size: 2.4rem; margin-bottom: 8px; line-height: 1; }
  .htimeline__title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--hindrishi-text-dark, #1C1C1C);
    margin: 0 0 8px;
  }
  .htimeline__desc {
    font-size: 1.4rem;
    color: var(--hindrishi-text-medium, #4A4A4A);
    line-height: 1.65;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Our Journey Timeline",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",  "id": "tag",        "label": "Section Tag",  "default": "Our Journey" },
    { "type": "text",  "id": "heading",    "label": "Heading",      "default": "How Hindrishi Began" },
    { "type": "text",  "id": "subheading", "label": "Subheading",   "default": "From a single vision to 40,000+ trusted families" },
    { "type": "color", "id": "bg_color",   "label": "Background",   "default": "#ffffff" },
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [{
    "type": "milestone", "name": "Milestone",
    "settings": [
      { "type": "text",     "id": "year",        "label": "Year / Period",   "default": "2018" },
      { "type": "text",     "id": "icon",        "label": "Emoji Icon",      "default": "🌱" },
      { "type": "color",    "id": "dot_color",   "label": "Timeline Dot Color", "default": "#2D5A27" },
      { "type": "text",     "id": "title",       "label": "Milestone Title", "default": "The Beginning" },
      { "type": "textarea", "id": "description", "label": "Description" }
    ]
  }],
  "presets": [{
    "name": "Our Journey Timeline",
    "blocks": [
      { "type": "milestone", "settings": { "year": "2018", "icon": "🌱", "dot_color": "#2D5A27", "title": "The Vision Takes Root", "description": "Hindrishi Ayurveda was founded on a simple but powerful belief: that India's 5,000-year healing tradition, when combined with modern quality standards, could genuinely improve everyday lives." } },
      { "type": "milestone", "settings": { "year": "2019", "icon": "🧪", "dot_color": "#8B5E3C", "title": "GMP Certification Achieved", "description": "We invested in a fully GMP-certified manufacturing facility — ensuring every product meets pharmaceutical-grade production standards before reaching our customers." } },
      { "type": "milestone", "settings": { "year": "2020", "icon": "🌿", "dot_color": "#2D5A27", "title": "First Products Launched", "description": "Launched our flagship Liv-Revive Liver Syrup and Kidney Wellness formulas, rooted in classical Ayurvedic texts and validated through rigorous third-party lab testing." } },
      { "type": "milestone", "settings": { "year": "2021", "icon": "👨‍👩‍👧", "dot_color": "#8B5E3C", "title": "10,000 Families Served", "description": "Word spread naturally. Our commitment to authentic ingredients and honest formulations resonated with Indian families who were tired of synthetic supplements." } },
      { "type": "milestone", "settings": { "year": "2023", "icon": "🏆", "dot_color": "#2D5A27", "title": "40,000+ Families Trust Hindrishi", "description": "Today, over 40,000 families across India rely on Hindrishi Ayurveda for their daily wellness. We remain committed to the same principles we started with — purity, authenticity, and trust." } }
    ]
  }]
}
{% endschema %}
